---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
---

<Layout
  title="404 — Page Not Found | Tyler Irving"
  description="The page you're looking for doesn't exist. Head back to Tyler Irving's portfolio."
>
  <Nav />
  <main class="not-found">
    <div class="container">
      <div class="nf-content">
        <span class="nf-code label-mono">404 — Page not found</span>
        <h1 class="nf-heading">That page doesn't exist.</h1>
        <p class="nf-body">You may have followed a broken link or typed the URL incorrectly.</p>
        <a href="/" class="btn-primary">Back to portfolio &rarr;</a>
      </div>
    </div>
  </main>
</Layout>

<style>
  .not-found {
    min-height: calc(100dvh - var(--nav-h));
    padding-top: var(--nav-h);
    display: flex;
    align-items: center;
  }

  .nf-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 560px;
    padding-block: 4rem;
    border-top: 1px solid var(--border);
  }

  .nf-code {
    /* inherits label-mono utility: font-mono, 0.6875rem, uppercase, text-faint */
  }

  .nf-heading {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--text);
    line-height: 1.0;
  }

  .nf-body {
    color: var(--text-muted);
    font-size: 1rem;
    max-width: 40ch;
    line-height: 1.6;
  }
</style>
