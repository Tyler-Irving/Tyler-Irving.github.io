---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
}

const {
  title = 'Tyler Irving | Senior RPA Developer & Automation Consultant',
  description = 'Tyler Irving — Senior RPA Developer & Automation Consultant with Secret Security Clearance. UiPath automation for the U.S. Navy at Baker Tilly, algorithmic trading systems, and full-stack apps in Python, Django, React, and TypeScript.',
  image = '/images/og-image.png',
  canonical,
} = Astro.props;

const siteUrl = 'https://tyler-irving.github.io';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).href;
const ogImage = new URL(image, siteUrl).href;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Charset & Viewport -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="Tyler Irving, RPA Developer, Automation Consultant, UiPath, Python developer, Django developer, React developer, TypeScript, full-stack developer, algorithmic trading, Kalshi, Secret Security Clearance, Baker Tilly, U.S. Navy, portfolio, software engineer, automation systems, live trading daemon"
    />
    <meta name="author" content="Tyler Irving" />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Tyler Irving" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:creator" content="@TylerIrving" />

    <!-- Theme Color -->
    <meta name="theme-color" content="#FAFAFA" />
    <meta name="color-scheme" content="light dark" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap.xml" />

    <!-- Fonts — Google Fonts (Archivo + Space Grotesk + JetBrains Mono) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,400&family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:ital,wght@0,400;0,500;1,400&display=swap"
    />

    <!-- Dark mode init — light is default; only go dark if user explicitly toggled -->
    <script is:inline>
      (function () {
        if (localStorage.getItem('theme') === 'dark') {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <!-- Structured Data: Person -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Tyler Irving",
        "url": "https://tyler-irving.github.io",
        "image": "https://tyler-irving.github.io/assets/tyler-irving.jpg",
        "jobTitle": "Senior RPA Developer & Automation Consultant",
        "description": "Senior RPA Developer with US Secret Security Clearance building UiPath automation for the U.S. Navy at Baker Tilly, plus algorithmic trading daemons and full-stack web applications.",
        "worksFor": {
          "@type": "Organization",
          "name": "Baker Tilly",
          "url": "https://www.bakertilly.com"
        },
        "hasOccupation": {
          "@type": "Occupation",
          "name": "Senior RPA Developer",
          "occupationLocation": {
            "@type": "Country",
            "name": "United States"
          },
          "skills": "UiPath, Python, Django, React, TypeScript, Robotic Process Automation, Automation Engineering"
        },
        "sameAs": [
          "https://github.com/Tyler-Irving",
          "https://www.linkedin.com/in/tyler-irving-94b567189/"
        ],
        "knowsAbout": [
          "Robotic Process Automation",
          "UiPath Studio",
          "UiPath Orchestrator",
          "UiPath AI Center",
          "Document Understanding",
          "Python",
          "Django",
          "Django REST Framework",
          "React",
          "TypeScript",
          "Full-Stack Development",
          "Software Engineering",
          "Algorithmic Trading",
          "Kalshi Prediction Markets",
          "Bayesian Probability",
          "Automation Systems",
          "Machine Learning",
          "Enterprise Automation",
          "U.S. Navy",
          "Secret Security Clearance"
        ]
      }
    </script>

    <!-- Structured Data: Portfolio Projects -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "ItemList",
        "name": "Tyler Irving — Portfolio Projects",
        "description": "Software projects built by Tyler Irving: trading systems, web apps, automation tools, and developer platforms.",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "item": {
              "@type": "WebApplication",
              "name": "Where is my data?",
              "url": "https://whereismydata.io",
              "description": "Interactive globe visualizing 181 cloud and colocation datacenters across 43 providers. Latency estimation, pricing comparison, and CSV/JSON export.",
              "applicationCategory": "DeveloperApplication",
              "author": { "@type": "Person", "name": "Tyler Irving" }
            }
          },
          {
            "@type": "ListItem",
            "position": 2,
            "item": {
              "@type": "WebApplication",
              "name": "AutoProspect",
              "description": "AI-powered lead intelligence tool for selling automation services. Draws radius on map, discovers local businesses, enriches them, and scores automation potential with Claude.",
              "applicationCategory": "BusinessApplication",
              "author": { "@type": "Person", "name": "Tyler Irving" }
            }
          },
          {
            "@type": "ListItem",
            "position": 3,
            "item": {
              "@type": "WebApplication",
              "name": "Weather Arbitrage Dashboard",
              "description": "Full-stack monitoring dashboard for a Kalshi weather arbitrage trading daemon. Live log streaming over WebSockets, P&L charts, and 34 analytics endpoints.",
              "applicationCategory": "FinanceApplication",
              "author": { "@type": "Person", "name": "Tyler Irving" }
            }
          },
          {
            "@type": "ListItem",
            "position": 4,
            "item": {
              "@type": "SoftwareApplication",
              "name": "Weather Arbitrage Daemon",
              "description": "Autonomous Python daemon trading mispriced temperature contracts on Kalshi using 5 ensemble models, Bayesian blending, and Quarter-Kelly position sizing.",
              "applicationCategory": "FinanceApplication",
              "author": { "@type": "Person", "name": "Tyler Irving" }
            }
          },
          {
            "@type": "ListItem",
            "position": 5,
            "item": {
              "@type": "SoftwareApplication",
              "name": "Crypto Trading Bot",
              "description": "Automated cryptocurrency trading daemon for Coinbase Advanced Trade API with RSI-14, MACD, EMA-12/26, volume spike, and support-bounce composite scoring.",
              "applicationCategory": "FinanceApplication",
              "author": { "@type": "Person", "name": "Tyler Irving" }
            }
          },
          {
            "@type": "ListItem",
            "position": 6,
            "item": {
              "@type": "WebApplication",
              "name": "File-to-API Platform",
              "description": "Upload a CSV or Excel file and instantly get a fully functional REST API with auth, rate limiting, pagination, and Swagger docs. Dynamic model generation at runtime.",
              "applicationCategory": "DeveloperApplication",
              "author": { "@type": "Person", "name": "Tyler Irving" }
            }
          }
        ]
      }
    </script>
  </head>

  <body>
    <slot />
  </body>

</html>
