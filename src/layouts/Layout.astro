  </head>

  <body>
    <slot />
  </body>

  <!--
    Shimmer button injection — port of ShimmerButton (React/framer-motion component).
    Injects the 4-element shimmer structure into every CTA after the DOM is ready.
    CSS variables per button type are defined in global.css and ProjectCard.astro.
  -->
  <script>
    function shimmerize(el: HTMLElement): void {
      // Idempotent — skip if already shimmerized
      if (el.querySelector('.shimmer-spark')) return;

      // Wrap existing children in display:contents span so text stays above shimmer layers
      const content = document.createElement('span');
      content.className = 'shimmer-content';
      while (el.firstChild) content.appendChild(el.firstChild);

      // 1. Spark container (overflow: visible, container-type: size, blur filter)
      const spark = document.createElement('span');
      spark.className = 'shimmer-spark';
      spark.setAttribute('aria-hidden', 'true');

      // 2. Slide element — moves L→R across the button via shimmer-slide keyframe
      const slide = document.createElement('span');
      slide.className = 'shimmer-slide';

      // 3. Rotate element — conic-gradient that spins inside the slide
      const rotate = document.createElement('span');
      rotate.className = 'shimmer-rotate';

      slide.appendChild(rotate);
      spark.appendChild(slide);

      // 4. Highlight — inset box-shadow overlay (brightens on hover)
      const highlight = document.createElement('span');
      highlight.className = 'shimmer-highlight';
      highlight.setAttribute('aria-hidden', 'true');

      // 5. Backdrop — opaque fill at inset:1px, exposes shimmer glow on the 1px border ring
      const backdrop = document.createElement('span');
      backdrop.className = 'shimmer-backdrop';
      backdrop.setAttribute('aria-hidden', 'true');

      el.appendChild(spark);
      el.appendChild(content);
      el.appendChild(highlight);
      el.appendChild(backdrop);
    }

    function initShimmer(): void {
      document
        .querySelectorAll<HTMLElement>('.btn-primary, .btn-ghost, .toggle-btn, .github-btn')
        .forEach(shimmerize);

      // Re-shimmerize any toggle buttons added dynamically (project card expand init
      // runs on the same DOMContentLoaded tick — MutationObserver handles any late ones)
      const observer = new MutationObserver((mutations) => {
        for (const m of mutations) {
          for (const node of m.addedNodes) {
            if (node instanceof HTMLElement) {
              node
                .querySelectorAll<HTMLElement>('.btn-primary, .btn-ghost, .toggle-btn, .github-btn')
                .forEach(shimmerize);
            }
          }
        }
      });
      observer.observe(document.body, { childList: true, subtree: true });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initShimmer);
    } else {
      initShimmer();
    }
  </script>
</html>
