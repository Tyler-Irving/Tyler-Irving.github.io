] as const;
---

<section id="projects" class="projects-section">
  <div class="container">
    <span class="section-label"><span class="section-num">002</span> Selected Work</span>
    <h2 class="section-heading">Things I shipped.</h2>

    <div class="projects-grid">
      {
        projects.map((project, i) => (
          <div class={`grid-item${featuredIds.has(project.id) ? ' grid-item--full' : ''}`}>
            <ProjectCard {...project} index={i + 1} />
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .projects-section {
    padding-block: var(--section-gap);
  }

  /* Section heading */
  .section-heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text);
    margin-bottom: 3rem;
    line-height: 1.1;
  }

  /* Grid layout */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  /* First card spans full width */
  .grid-item--full {
    grid-column: 1 / -1;
  }

  /* All other items: normal column span */
  .grid-item {
    display: flex;
    flex-direction: column;
  }

  /* Make the card fill its grid cell height */
  .grid-item > :global(.project-card) {
    flex: 1;
  }

  /* Responsive: single column on mobile */
  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }

    .grid-item--full {
      grid-column: 1;
    }

    .section-heading {
      margin-bottom: 2rem;
    }
  }
</style>
