---
// Hero.astro — Editorial asymmetric layout
// Off-White x Apple x Nike direction
// No avatar. Massive display type + info column.
---

<section class="hero" id="hero" aria-label="Introduction">
  <div class="hero-inner">

    <!-- ── Main display type ─────────────────────────────── -->
    <div class="hero-display" id="hero-display">
      <h1 class="hero-name" aria-label="Tyler Irving">IRVING</h1>
      <p class="hero-sub">
        <em>c/o</em> <span class="hero-role-quote">&ldquo;software engineer&rdquo;</span>
      </p>
    </div>

    <!-- ── Info column ───────────────────────────────────── -->
    <div class="hero-info" id="hero-info" aria-label="Details">
      <dl class="info-grid">
        <div class="info-row">
          <dt class="label-mono">Role</dt>
          <dd>Senior RPA Developer</dd>
        </div>
        <div class="info-row">
          <dt class="label-mono">Company</dt>
          <dd>Baker Tilly</dd>
        </div>
        <div class="info-row">
          <dt class="label-mono">Clearance</dt>
          <dd>US Secret</dd>
        </div>
        <div class="info-row">
          <dt class="label-mono">Status</dt>
          <dd class="status-available">
            <span class="status-dot" aria-hidden="true"></span>
            Available
          </dd>
        </div>
      </dl>
    </div>

  </div>

  <!-- ── Diagonal rule ─────────────────────────────────── -->
  <div class="hero-rule-wrap" id="hero-rule">
    <div class="diagonal-rule"></div>
  </div>

  <!-- ── CTAs ──────────────────────────────────────────── -->
  <div class="hero-ctas container" id="hero-ctas">
    <a href="#projects" class="btn-primary">View Work &rarr;</a>
    <a
      href="https://github.com/Tyler-Irving"
      target="_blank"
      rel="noopener noreferrer me"
      class="btn-ghost"
    >GitHub &nearr;</a>
    <a
      href="https://www.linkedin.com/in/tyler-irving-94b567189/"
      target="_blank"
      rel="noopener noreferrer me"
      class="btn-ghost"
    >LinkedIn &nearr;</a>
  </div>

</section>

<style>
  /* ── Section shell ──────────────────────────────────────── */
  .hero {
    min-height: calc(100vh - var(--nav-h));
    padding-top: calc(var(--nav-h) + clamp(3rem, 8vh, 6rem));
    padding-bottom: clamp(4rem, 8vh, 6rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: clamp(2rem, 4vh, 3rem);
    overflow: hidden;
  }

  /* ── Inner: display + info side by side ─────────────────── */
  .hero-inner {
    max-width: var(--max-w);
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 3rem);
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: clamp(2rem, 6vw, 5rem);
  }

  /* ── Display type ───────────────────────────────────────── */
  .hero-display {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(5rem, 18vw, 16rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 0.88;
    text-transform: uppercase;
    color: var(--text);
    /* Intentionally bleed slightly left for editorial feel */
    margin-left: -0.03em;
  }

  .hero-sub {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.375rem);
    font-weight: 400;
    color: var(--text-muted);
    letter-spacing: 0.01em;
  }

  .hero-sub em {
    font-style: italic;
    margin-right: 0.25em;
  }

  .hero-role-quote {
    font-style: italic;
  }

  /* ── Info column ────────────────────────────────────────── */
  .hero-info {
    padding-bottom: 0.25rem;
    flex-shrink: 0;
  }

  .info-grid {
    display: flex;
    flex-direction: column;
    min-width: 180px;
  }

  .info-row {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 1rem;
    align-items: baseline;
    padding-block: 0.75rem;
    border-top: 1px solid var(--border);
  }

  .info-row:last-child {
    border-bottom: 1px solid var(--border);
  }

  .info-row dt {
    color: var(--text-faint);
    flex-shrink: 0;
  }

  .info-row dd {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text);
  }

  .status-available {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--accent) !important;
  }

  .status-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }

  /* ── Rule ───────────────────────────────────────────────── */
  .hero-rule-wrap {
    max-width: var(--max-w);
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 3rem);
  }

  /* ── CTAs ───────────────────────────────────────────────── */
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  /* ── GSAP initial state ─────────────────────────────────── */
  #hero-display,
  #hero-info,
  #hero-rule,
  #hero-ctas {
    opacity: 0;
  }

  /* ── Responsive ─────────────────────────────────────────── */
  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .hero-info {
      border-top: 1px solid var(--border);
      padding-top: 1.5rem;
    }

    .info-row:first-child {
      border-top: none;
    }

    .hero-name {
      font-size: clamp(4rem, 22vw, 8rem);
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';
  import Lenis from 'lenis';

  gsap.registerPlugin(ScrollTrigger);

  // ── Smooth scroll ──────────────────────────────────────────
  const lenis = new Lenis({ lerp: 0.08, smoothWheel: true });
  gsap.ticker.add((time) => lenis.raf(time * 1000));
  gsap.ticker.lagSmoothing(0);
  lenis.on('scroll', () => ScrollTrigger.update());

  // ── Hero entrance ──────────────────────────────────────────
  function animateHeroIn() {
    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

    tl.to('#hero-display', { opacity: 1, y: 0, duration: 0.7, clearProps: 'transform' }, 0)
      .to('#hero-info',    { opacity: 1, y: 0, duration: 0.6 }, 0.15)
      .to('#hero-rule',    { opacity: 1, y: 0, duration: 0.5 }, 0.3)
      .to('#hero-ctas',    { opacity: 1, y: 0, duration: 0.5 }, 0.4)
      .add(() => ScrollTrigger.refresh());
  }

  // Set initial translate state
  gsap.set(['#hero-display', '#hero-info', '#hero-rule', '#hero-ctas'], { y: 28 });

  if (sessionStorage.getItem('booted') === 'true') {
    animateHeroIn();
  } else {
    document.addEventListener('bootComplete', animateHeroIn);
  }

  // ── Scroll reveals ─────────────────────────────────────────
  gsap.utils.toArray<Element>('[data-animate="fadeUp"]').forEach((el) => {
    gsap.set(el, { y: 32, opacity: 0 });
    gsap.to(el, {
      y: 0,
      opacity: 1,
      duration: 0.7,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: el,
        start: 'top 92%',
        once: true,
      },
    });
  });

  ScrollTrigger.refresh();
</script>
