---
// TerminalBoot.astro — Typographic intro animation
// Letters of "IRVING" animate in sequentially on first visit.
// Fires 'bootComplete' event when done, sets sessionStorage.booted = 'true'.
// On return visits, instantly fires bootComplete and skips animation.
---

<div class="boot-overlay" id="boot-overlay" aria-hidden="true">
  <div class="boot-word" id="boot-word">
    {'IRVING'.split('').map((char) => (
      <span class="boot-char" aria-hidden="true">{char}</span>
    ))}
  </div>
</div>

<style>
  .boot-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: var(--bg);
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .boot-word {
    display: flex;
    align-items: baseline;
    gap: 0.04em;
    overflow: hidden;
  }

  .boot-char {
    display: inline-block;
    font-family: var(--font-display);
    font-size: clamp(4rem, 14vw, 11rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    color: var(--text);
    opacity: 0;
    transform: translateY(40px);
    will-change: transform, opacity;
  }
</style>

<script>
  import gsap from 'gsap';

  const overlay = document.getElementById('boot-overlay');
  const chars = document.querySelectorAll<HTMLElement>('.boot-char');

  function dispatchBoot() {
    document.dispatchEvent(new CustomEvent('bootComplete'));
  }

  if (sessionStorage.getItem('booted') === 'true') {
    // Return visit — hide overlay immediately, fire event
    if (overlay) overlay.style.display = 'none';
    dispatchBoot();
  } else {
    // First visit — run animation
    const tl = gsap.timeline({
      onComplete: () => {
        sessionStorage.setItem('booted', 'true');
        gsap.to(overlay, {
          opacity: 0,
          duration: 0.5,
          ease: 'power2.in',
          delay: 0.2,
          onComplete: () => {
            if (overlay) overlay.style.display = 'none';
            dispatchBoot();
          },
        });
      },
    });

    // Stagger letters in from below
    tl.to(chars, {
      opacity: 1,
      y: 0,
      duration: 0.55,
      ease: 'power3.out',
      stagger: 0.07,
    });

    // Brief hold, then slight scale before exit
    tl.to('.boot-word', {
      scale: 1.04,
      duration: 0.35,
      ease: 'power2.inOut',
      delay: 0.15,
    });
  }
</script>
