---
// Nav.astro
// Floating pill navigation, fixed at top center.
// Hides on scroll-down past 100px, shows on scroll-up.
// Active link tracks current section via IntersectionObserver.
---

<nav class="floating-nav" aria-label="Site navigation">
  <!-- Corner HUD brackets -->
  <span class="nav-bracket nav-bracket--tl" aria-hidden="true"></span>
  <span class="nav-bracket nav-bracket--tr" aria-hidden="true"></span>
  <!-- Top accent line -->
  <div class="nav-accent-line" aria-hidden="true"></div>

  <a href="#projects" class="nav-link">
    <span class="nav-num" aria-hidden="true">001</span>
    Projects
  </a>
  <span class="nav-sep" aria-hidden="true"></span>
  <a href="#work" class="nav-link">
    <span class="nav-num" aria-hidden="true">002</span>
    Work
  </a>
  <span class="nav-sep" aria-hidden="true"></span>
  <a href="#skills" class="nav-link">
    <span class="nav-num" aria-hidden="true">003</span>
    Skills
  </a>
</nav>

<style>
  /* ── Nav shell — sharp HUD rectangle ─────────────────────── */
  .floating-nav {
    position: fixed;
    top: 24px;
    left: 0;
    right: 0;
    width: fit-content;
    margin: 0 auto;
    z-index: 1000;

    display: flex;
    align-items: center;
    gap: 0;
    padding: 8px 20px;

    border-radius: 2px;
    border: 1px solid rgba(14, 165, 233, 0.2);
    background: rgba(8, 8, 8, 0.85);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    box-shadow:
      0 4px 32px rgba(0, 0, 0, 0.6),
      0 0 0 1px rgba(14, 165, 233, 0.04) inset;
  }

  /* ── Top accent line ──────────────────────────────────────── */
  .nav-accent-line {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(14, 165, 233, 0.55) 30%,
      rgba(56, 189, 248, 0.8) 50%,
      rgba(14, 165, 233, 0.55) 70%,
      transparent 100%
    );
    opacity: 0.45;
    pointer-events: none;
  }

  /* ── Corner HUD brackets ──────────────────────────────────── */
  .nav-bracket {
    position: absolute;
    width: 8px;
    height: 8px;
    pointer-events: none;
  }

  .nav-bracket--tl {
    top: 4px; left: 4px;
    border-top: 1px solid rgba(14, 165, 233, 0.4);
    border-left: 1px solid rgba(14, 165, 233, 0.4);
  }

  .nav-bracket--tr {
    top: 4px; right: 4px;
    border-top: 1px solid rgba(14, 165, 233, 0.4);
    border-right: 1px solid rgba(14, 165, 233, 0.4);
  }

  /* ── Vertical separator ───────────────────────────────────── */
  .nav-sep {
    display: inline-block;
    width: 1px;
    height: 14px;
    background: rgba(14, 165, 233, 0.18);
    margin: 0 6px;
    flex-shrink: 0;
  }

  /* ── Nav links ────────────────────────────────────────────── */
  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 10px;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    text-decoration: none;
    cursor: pointer;
    transition: color var(--transition);
    will-change: transform;
    /* Reserve bracket space to prevent layout shift */
    position: relative;
  }

  /* Always-present brackets — invisible until hover/active */
  .nav-link::before {
    content: '[';
    font-family: var(--font-mono);
    font-size: 0.65rem;
    opacity: 0;
    color: rgba(14, 165, 233, 0.65);
    transition: opacity var(--transition);
    margin-right: -2px;
  }

  .nav-link::after {
    content: ']';
    font-family: var(--font-mono);
    font-size: 0.65rem;
    opacity: 0;
    color: rgba(14, 165, 233, 0.65);
    transition: opacity var(--transition);
    margin-left: -2px;
  }

  .nav-link:hover {
    color: rgba(255, 255, 255, 0.75);
  }

  .nav-link:hover::before,
  .nav-link:hover::after {
    opacity: 0.4;
  }

  .nav-link.active {
    color: var(--accent-light);
  }

  .nav-link.active::before,
  .nav-link.active::after {
    opacity: 1;
    color: var(--accent-light);
  }

  /* ── Section index number ─────────────────────────────────── */
  .nav-num {
    font-family: var(--font-mono);
    font-size: 0.475rem;
    letter-spacing: 0.18em;
    color: rgba(14, 165, 233, 0.35);
    transition: color var(--transition);
    flex-shrink: 0;
    align-self: flex-start;
    margin-top: 1px;
  }

  .nav-link:hover .nav-num {
    color: rgba(14, 165, 233, 0.55);
  }

  .nav-link.active .nav-num {
    color: rgba(56, 189, 248, 0.7);
  }

  /* ── Mobile — hide section numbers ───────────────────────── */
  @media (max-width: 480px) {
    .nav-num {
      display: none;
    }

    .floating-nav {
      padding: 8px 14px;
    }

    .nav-link {
      padding: 4px 8px;
      font-size: 0.65rem;
    }
  }
</style>

<script>
  import gsap from 'gsap';

  const nav = document.querySelector<HTMLElement>('.floating-nav');
  const links = document.querySelectorAll<HTMLAnchorElement>('.nav-link');

  if (!nav) throw new Error('Nav element not found');

  // ----------------------------------------------------------------
  // Smooth scroll on link click
  // ----------------------------------------------------------------
  links.forEach((link) => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const href = link.getAttribute('href');
      if (!href) return;
      const target = document.querySelector<HTMLElement>(href);
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  // ----------------------------------------------------------------
  // Hide / show on scroll direction
  // ----------------------------------------------------------------
  let lastScrollY = window.scrollY;
  let isHidden = false;

  gsap.set(nav, { yPercent: 0 });

  function showNav() {
    if (!isHidden) return;
    isHidden = false;
    gsap.to(nav, {
      yPercent: 0,
      opacity: 1,
      duration: 0.45,
      ease: 'power3.out',
    });
  }

  function hideNav() {
    if (isHidden) return;
    isHidden = true;
    gsap.to(nav, {
      yPercent: -200,
      opacity: 0,
      duration: 0.35,
      ease: 'power3.in',
    });
  }

  window.addEventListener('scroll', () => {
    const currentScrollY = window.scrollY;
    const scrollingDown = currentScrollY > lastScrollY;

    if (scrollingDown && currentScrollY > 100) {
      hideNav();
    } else {
      showNav();
    }

    lastScrollY = currentScrollY;
  }, { passive: true });

  // ----------------------------------------------------------------
  // Active link tracking via IntersectionObserver
  // ----------------------------------------------------------------
  const sectionIds = ['projects', 'work', 'skills'];
  const sectionMap = new Map<string, HTMLElement>();

  sectionIds.forEach((id) => {
    const el = document.getElementById(id);
    if (el) sectionMap.set(id, el);
  });

  function setActiveLink(activeId: string | null) {
    links.forEach((link) => {
      const href = link.getAttribute('href');
      if (href === `#${activeId}`) {
        link.classList.add('active');
      } else {
        link.classList.remove('active');
      }
    });
  }

  // Track which sections are currently intersecting
  const intersecting = new Set<string>();

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        const id = entry.target.id;
        if (entry.isIntersecting) {
          intersecting.add(id);
        } else {
          intersecting.delete(id);
        }
      });

      // Prefer the first section (in DOM order) that is currently visible
      let active: string | null = null;
      for (const id of sectionIds) {
        if (intersecting.has(id)) {
          active = id;
          break;
        }
      }

      setActiveLink(active);
    },
    {
      // Trigger when section occupies >=20% of viewport
      threshold: 0.2,
      rootMargin: '-10% 0px -10% 0px',
    }
  );

  sectionMap.forEach((el) => observer.observe(el));

  // ----------------------------------------------------------------
  // Hover: scale via GSAP for extra smoothness
  // ----------------------------------------------------------------
  links.forEach((link) => {
    link.addEventListener('mouseenter', () => {
      gsap.to(link, { scale: 1.05, duration: 0.2, ease: 'power2.out' });
    });
    link.addEventListener('mouseleave', () => {
      gsap.to(link, { scale: 1, duration: 0.2, ease: 'power2.out' });
    });
  });
</script>
