<style>
  .work-section {
    padding-block: var(--section-gap);
  }

  .work-stack {
    display: flex;
    flex-direction: column;
  }

  /* ── Role card — editorial timeline ───────────────────────── */
  .role-card {
    border-top: 1px solid var(--border);
    position: relative;
    transition: background var(--transition);
  }

  .role-card:last-child {
    border-bottom: 1px solid var(--border);
  }

  /* Active card: blue left border accent */
  .role-card--active {
    border-left: 2px solid var(--accent);
  }

  /* Remove the top border overlap with left border for active card */
  .role-card--active .role-inner {
    padding-left: calc(1.5rem - 2px);
  }

  .role-inner {
    padding: 1.75rem 1.5rem;
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto auto auto;
    gap: 0 2rem;
    align-items: start;
  }

  /* ── Status + period row ──────────────────────────────────── */
  .role-status-row {
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .status-indicator {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--border-hover);
    flex-shrink: 0;
  }

  .status-dot--active {
    background: var(--accent);
    animation: status-pulse 2.5s ease-in-out infinite;
  }

  @keyframes status-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(37, 99, 235, 0.3); }
    50%       { box-shadow: 0 0 0 5px rgba(37, 99, 235, 0); }
  }

  .status-text {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    color: var(--text-faint);
    text-transform: uppercase;
  }

  .status-text--active {
    color: var(--accent);
  }

  .role-period {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--text-faint);
    letter-spacing: 0.04em;
  }

  /* ── Identity ─────────────────────────────────────────────── */
  .role-identity {
    grid-column: 1;
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }

  .role-monogram {
    width: 40px;
    height: 40px;
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--text-muted);
    flex-shrink: 0;
    transition: border-color var(--transition);
  }

  .role-card--active .role-monogram {
    border-color: var(--accent);
    color: var(--accent);
  }

  .role-meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1;
    min-width: 0;
  }

  .role-company {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text);
    line-height: 1.1;
  }

  .role-title {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }

  .clearance-badge {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    padding: 0.2rem 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: var(--accent);
    border: 1px solid var(--accent);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── Divider ──────────────────────────────────────────────── */
  .role-divider {
    grid-column: 1 / -1;
    width: 100%;
    height: 1px;
    background: var(--border);
    margin-block: 0.75rem;
  }

  /* ── Tagline ──────────────────────────────────────────────── */
  .role-tagline {
    grid-column: 1 / -1;
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 0.875rem;
    font-style: italic;
  }

  /* ── Bullets ──────────────────────────────────────────────── */
  .role-bullets {
    grid-column: 1 / -1;
    list-style: none;
    margin: 0 0 1rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .role-bullets li {
    position: relative;
    padding-left: 1.25rem;
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.65;
  }

  .role-bullets li::before {
    content: '—';
    position: absolute;
    left: 0;
    top: 0;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-faint);
    line-height: 1.65;
  }

  /* ── Footer ───────────────────────────────────────────────── */
  .role-footer {
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    flex-wrap: wrap;
    padding-top: 0.875rem;
    border-top: 1px solid var(--border);
  }

  .role-tag {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-faint);
    border: 1px solid var(--border);
    padding: 0.2rem 0.5rem;
  }

  .role-index {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.14em;
    color: var(--text-faint);
    flex-shrink: 0;
  }

  /* ── Mobile ───────────────────────────────────────────────── */
  @media (max-width: 600px) {
    .role-inner {
      padding: 1.25rem 1rem;
      grid-template-columns: 1fr;
    }

    .role-status-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }

    .clearance-badge {
      align-self: auto;
    }
  }
</style>
