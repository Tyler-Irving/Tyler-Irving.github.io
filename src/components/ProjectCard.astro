---
interface Props {
  id: string;
  title: string;
  icon: string;        // kept for data compat, not rendered
  oneliner: string;
  description: string;
  tech: string[];
  github: string;
  liveUrl?: string;
  stats: { label: string; value: string }[];
  decisions: string[];
  footer?: string;
  index?: number;      // 1-based, for the HUD card number
}

const {
  id, title, oneliner, description,
  tech, github, liveUrl, stats, decisions,
  footer, index = 1,
} = Astro.props;

const cardNum  = String(index).padStart(3, '0');
// Show max 5 tech badges; remainder as "+N"
const MAX_TECH = 5;
const visibleTech  = tech.slice(0, MAX_TECH);
const overflowTech = tech.length > MAX_TECH ? tech.length - MAX_TECH : 0;
---

<article
  class="project-card"
  data-card-id={id}
  data-animate="fadeUp"
>
  <!-- ── Collapsed header (always visible) ── -->
  <div class="card-header">

    <div class="card-index-row" aria-hidden="true">
      <span class="card-num label-mono">{cardNum}</span>
      <span class="card-rule"></span>
      {liveUrl && (
        <a href={liveUrl} target="_blank" rel="noopener noreferrer" class="card-live-link label-mono">
          Live &nearr;
        </a>
      )}
    </div>

    <div class="card-title-row">
      <h3 class="card-title">{title}</h3>
      <button
        class="toggle-btn"
        data-toggle={id}
        aria-expanded="false"
        aria-controls={`expand-${id}`}
      >
        <span class="toggle-text">Details</span>
      </button>
    </div>

    <p class="card-oneliner">{oneliner}</p>

    <div class="tech-row">
      {visibleTech.map((t) => <span class="tech-badge">{t}</span>)}
      {overflowTech > 0 && <span class="tech-badge tech-badge--more">+{overflowTech}</span>}
    </div>

  </div>

  <!-- ── Expanded content ── -->
  <div class="card-expand" id={`expand-${id}`} data-expand={id} aria-hidden="true">
    <div class="card-expand-inner">

      <div class="expand-divider" aria-hidden="true"></div>

      {stats.length > 0 && (
        <div class="expand-section">
          <span class="expand-label label-mono">The Numbers</span>
          <div class="stats-row">
            {stats.map((s) => (
              <div class="stat-box">
                <span class="stat-value">{s.value}</span>
                <span class="stat-label label-mono">{s.label}</span>
              </div>
            ))}
          </div>
        </div>
      )}

      <div class="expand-section">
        <span class="expand-label label-mono">What I Built</span>
        <p class="expand-description">{description}</p>
      </div>

      {decisions.length > 0 && (
        <div class="expand-section">
          <span class="expand-label label-mono">Key Decisions</span>
          <ul class="decisions-list">
            {decisions.map((d) => (
              <li class="decision-item">
                <span class="decision-arrow" aria-hidden="true">—</span>
                <span>{d}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      <div class="expand-footer">
        <a href={github} target="_blank" rel="noopener noreferrer" class="btn-ghost github-btn">
          GitHub &nearr;
        </a>
        {footer && <span class="footer-note label-mono">{footer}</span>}
      </div>

    </div>
  </div>
</article>

<style>
  /* ── Card shell ──────────────────────────────────────── */
  .project-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 0;
    transition:
      border-color var(--transition),
      box-shadow var(--transition);
    cursor: default;
  }

  .project-card:hover:not(.is-expanded) {
    border-color: var(--border-hover);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
  }

  .project-card.is-expanded {
    border-color: var(--accent);
  }

  /* ── Header ──────────────────────────────────────────── */
  .card-header {
    padding: 1.5rem;
  }

  .card-index-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .card-num {
    color: var(--text-faint);
    flex-shrink: 0;
  }

  .card-rule {
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .card-live-link {
    color: var(--accent);
    text-decoration: none;
    flex-shrink: 0;
    transition: opacity var(--transition);
  }

  .card-live-link:hover {
    opacity: 0.7;
  }

  /* Title row */
  .card-title-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.625rem;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text);
    line-height: 1.15;
  }

  /* Oneliner */
  .card-oneliner {
    color: var(--text-muted);
    font-size: 0.875rem;
    line-height: 1.6;
    margin-bottom: 1.125rem;
  }

  /* ── Tech badges ─────────────────────────────────────── */
  .tech-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .tech-badge--more {
    color: var(--text-faint);
  }

  /* ── Toggle button ───────────────────────────────────── */
  .toggle-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 0.875rem;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 0;
    color: var(--text-muted);
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
    transition:
      border-color var(--transition),
      color var(--transition);
  }

  .toggle-btn:hover {
    border-color: var(--text);
    color: var(--text);
  }

  .toggle-btn[aria-expanded='true'] {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* ── Expand panel ────────────────────────────────────── */
  .card-expand {
    height: 0;
    overflow: hidden;
    opacity: 0;
  }

  .card-expand-inner {
    padding: 0 1.5rem 1.5rem;
  }

  .expand-divider {
    width: 100%;
    height: 1px;
    background: var(--border);
    margin-bottom: 1.5rem;
  }

  .expand-section {
    margin-bottom: 1.5rem;
  }

  .expand-label {
    display: block;
    color: var(--text-faint);
    margin-bottom: 0.75rem;
  }

  /* ── Stats grid ──────────────────────────────────────── */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(80px, 1fr));
    gap: 0.5rem;
  }

  .stat-box {
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 0.875rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    transition: border-color var(--transition);
  }

  .stat-box:hover {
    border-color: var(--border-hover);
  }

  .stat-value {
    font-family: var(--font-mono);
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    line-height: 1.1;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  /* ── Description ─────────────────────────────────────── */
  .expand-description {
    color: var(--text-muted);
    font-size: 0.875rem;
    line-height: 1.72;
  }

  /* ── Decisions ───────────────────────────────────────── */
  .decisions-list {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .decision-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--text-muted);
  }

  .decision-arrow {
    color: var(--text-faint);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    flex-shrink: 0;
    margin-top: 0.2em;
  }

  /* ── Expand footer ───────────────────────────────────── */
  .expand-footer {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .github-btn {
    font-size: 0.8125rem;
    padding: 0.5rem 1.125rem;
  }

  .footer-note {
    color: var(--text-faint);
  }

  /* ── Mobile ──────────────────────────────────────────── */
  @media (max-width: 600px) {
    .card-header {
      padding: 1.25rem;
    }

    .card-expand-inner {
      padding: 0 1.25rem 1.25rem;
    }

    .card-title {
      font-size: 1.125rem;
    }

    .stat-value {
      font-size: 1.125rem;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';

  let openCardId: string | null = null;
  const timelines = new Map<string, gsap.core.Timeline>();

  const grid = document.querySelector<HTMLElement>('.projects-grid');
  function setGridAlignment(mode: 'start' | '') {
    grid?.querySelectorAll<HTMLElement>('.grid-item').forEach((item) => {
      item.style.alignSelf = mode;
    });
  }

  function buildTimeline(expandEl: HTMLElement): gsap.core.Timeline {
    return gsap.timeline({ paused: true }).fromTo(
      expandEl,
      { height: 0, opacity: 0 },
      { height: 'auto', opacity: 1, duration: 0.45, ease: 'power2.out' }
    );
  }

  function openCard(cardId: string): void {
    const expandEl  = document.querySelector<HTMLElement>(`[data-expand="${cardId}"]`);
    const toggleBtn = document.querySelector<HTMLButtonElement>(`[data-toggle="${cardId}"]`);
    const cardEl    = document.querySelector<HTMLElement>(`[data-card-id="${cardId}"]`);
    if (!expandEl || !toggleBtn || !cardEl) return;

    if (!timelines.has(cardId)) timelines.set(cardId, buildTimeline(expandEl));
    timelines.get(cardId)!.play();

    toggleBtn.setAttribute('aria-expanded', 'true');
    expandEl.setAttribute('aria-hidden', 'false');
    cardEl.classList.add('is-expanded');

    const textEl = toggleBtn.querySelector<HTMLElement>('.toggle-text');
    if (textEl) textEl.textContent = 'Close';

    openCardId = cardId;
    setGridAlignment('start');
  }

  function closeCard(cardId: string): void {
    const expandEl  = document.querySelector<HTMLElement>(`[data-expand="${cardId}"]`);
    const toggleBtn = document.querySelector<HTMLButtonElement>(`[data-toggle="${cardId}"]`);
    const cardEl    = document.querySelector<HTMLElement>(`[data-card-id="${cardId}"]`);
    if (!expandEl || !toggleBtn || !cardEl) return;

    timelines.get(cardId)?.reverse();

    toggleBtn.setAttribute('aria-expanded', 'false');
    expandEl.setAttribute('aria-hidden', 'true');
    cardEl.classList.remove('is-expanded');

    const textEl = toggleBtn.querySelector<HTMLElement>('.toggle-text');
    if (textEl) textEl.textContent = 'Details';

    if (openCardId === cardId) openCardId = null;
    if (openCardId === null) {
      gsap.delayedCall(0.5, () => { if (openCardId === null) setGridAlignment(''); });
    }
  }

  (window as any).closeAllCards = function (): void {
    if (openCardId) closeCard(openCardId);
  };

  function initCard(toggleBtn: HTMLButtonElement): void {
    const cardId = toggleBtn.getAttribute('data-toggle');
    if (!cardId) return;
    toggleBtn.addEventListener('click', () => {
      const isOpen = toggleBtn.getAttribute('aria-expanded') === 'true';
      if (isOpen) {
        closeCard(cardId);
      } else {
        if (openCardId && openCardId !== cardId) closeCard(openCardId);
        openCard(cardId);
      }
    });
  }

  function initAll(): void {
    document.querySelectorAll<HTMLButtonElement>('[data-toggle]').forEach(initCard);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAll);
  } else {
    initAll();
  }
</script>
