---
interface Props {
  id: string;
  title: string;
  icon: string;        // kept for data compat, not rendered
  oneliner: string;
  description: string;
  tech: string[];
  github: string;
  liveUrl?: string;
  stats: { label: string; value: string }[];
  decisions: string[];
  footer?: string;
  index?: number;      // 1-based, for the HUD card number
}

const {
  id, title, oneliner, description,
  tech, github, liveUrl, stats, decisions,
  footer, index = 1,
} = Astro.props;

const cardNum  = String(index).padStart(3, '0');
// Show max 5 tech badges; remainder as "+N"
const MAX_TECH = 5;
const visibleTech  = tech.slice(0, MAX_TECH);
const overflowTech = tech.length > MAX_TECH ? tech.length - MAX_TECH : 0;
// Header stats: first 3 only
const headerStats = stats.slice(0, 3);
---

<article
  class="project-card"
  data-card-id={id}
  data-animate="fadeUp"
>
  <!-- Top accent gradient line -->
  <div class="card-accent-line" aria-hidden="true"></div>

  <!-- Corner brackets -->
  <span class="bracket bracket--tl" aria-hidden="true"></span>
  <span class="bracket bracket--tr" aria-hidden="true"></span>

  <!-- ── Collapsed header (always visible) ── -->
  <div class="card-header">

    <!-- Card index + separator -->
    <div class="card-index-row" aria-hidden="true">
      <span class="card-num">{cardNum}</span>
      <span class="card-rule"></span>
    </div>

    <!-- Title + toggle on same row -->
    <div class="card-title-row">
      <h3 class="card-title">{title}</h3>
      <button
        class="toggle-btn"
        data-toggle={id}
        aria-expanded="false"
        aria-controls={`expand-${id}`}
      >
        <span class="toggle-text">[ CASE STUDY ]</span>
      </button>
    </div>

    <!-- Oneliner -->
    <p class="card-oneliner">
      {oneliner}
      {liveUrl && (
        <a href={liveUrl} target="_blank" rel="noopener noreferrer" class="card-live-link">
          ↗ Live
        </a>
      )}
    </p>

    <!-- Header stats (always visible) -->
    {headerStats.length > 0 && (
      <div class="header-stats">
        {headerStats.map((s) => (
          <div class="hstat">
            <span class="hstat-value">{s.value}</span>
            <span class="hstat-label">{s.label}</span>
          </div>
        ))}
      </div>
    )}

    <!-- Tech badges -->
    <div class="tech-row">
      {visibleTech.map((t) => <span class="tech-badge">{t}</span>)}
      {overflowTech > 0 && <span class="tech-badge tech-badge--more">+{overflowTech}</span>}
    </div>

  </div>

  <!-- ── Expanded content ── -->
  <div class="card-expand" id={`expand-${id}`} data-expand={id} aria-hidden="true">
    <div class="card-expand-inner">

      <div class="expand-divider" aria-hidden="true"></div>

      <!-- Stats grid -->
      {stats.length > 0 && (
        <div class="expand-section">
          <span class="expand-label">── The Numbers ──────────────────</span>
          <div class="stats-row">
            {stats.map((s) => (
              <div class="stat-box">
                <span class="stat-value">{s.value}</span>
                <span class="stat-label">{s.label}</span>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- What I built -->
      <div class="expand-section">
        <span class="expand-label">── What I Built ─────────────────</span>
        <p class="expand-description">{description}</p>
      </div>

      <!-- Key decisions -->
      {decisions.length > 0 && (
        <div class="expand-section">
          <span class="expand-label">── Key Decisions ────────────────</span>
          <ul class="decisions-list">
            {decisions.map((d) => (
              <li class="decision-item">
                <span class="decision-arrow" aria-hidden="true">→</span>
                <span>{d}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Footer -->
      <div class="expand-footer">
        <a href={github} target="_blank" rel="noopener noreferrer" class="github-btn">
          → GITHUB
        </a>
        {footer && <span class="footer-note">{footer}</span>}
      </div>

    </div>
  </div>
</article>

<style>
  /* ── Card shell ──────────────────────────────────────── */
  .project-card {
    position: relative;
    background: linear-gradient(180deg, #111111 0%, #0c0c0c 100%);
    border: 1px solid rgba(14, 165, 233, 0.1);
    border-radius: 2px;
    transition:
      border-color var(--transition),
      box-shadow var(--transition),
      transform var(--transition);
    cursor: default;
  }

  .project-card:hover:not(.is-expanded) {
    border-color: rgba(14, 165, 233, 0.22);
    transform: translateY(-3px);
    box-shadow:
      0 12px 40px rgba(0, 0, 0, 0.55),
      0 0 0 1px rgba(14, 165, 233, 0.06) inset;
  }

  .project-card.is-expanded {
    border-color: rgba(14, 165, 233, 0.28);
    box-shadow: 0 8px 48px rgba(14, 165, 233, 0.08);
  }

  /* ── Top accent line ─────────────────────────────────── */
  .card-accent-line {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(14, 165, 233, 0.5) 35%,
      rgba(56, 189, 248, 0.75) 50%,
      rgba(14, 165, 233, 0.5) 65%,
      transparent 100%
    );
    opacity: 0.35;
    transition: opacity var(--transition);
    z-index: 1;
    pointer-events: none;
  }

  .project-card:hover .card-accent-line,
  .project-card.is-expanded .card-accent-line {
    opacity: 1;
  }

  /* ── Corner brackets ─────────────────────────────────── */
  .bracket {
    position: absolute;
    width: 14px;
    height: 14px;
    pointer-events: none;
    z-index: 2;
  }

  .bracket--tl {
    top: 8px; left: 8px;
    border-top: 1px solid rgba(14, 165, 233, 0.35);
    border-left: 1px solid rgba(14, 165, 233, 0.35);
  }

  .bracket--tr {
    top: 8px; right: 8px;
    border-top: 1px solid rgba(14, 165, 233, 0.35);
    border-right: 1px solid rgba(14, 165, 233, 0.35);
  }

  .project-card:hover .bracket,
  .project-card.is-expanded .bracket {
    border-color: rgba(14, 165, 233, 0.65);
  }

  /* ── Header ──────────────────────────────────────────── */
  .card-header {
    padding: 1.5rem 1.5rem 1.25rem;
  }

  /* Index row */
  .card-index-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.875rem;
  }

  .card-num {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    color: rgba(56, 189, 248, 0.45);
    flex-shrink: 0;
  }

  .card-rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, rgba(14, 165, 233, 0.2), transparent);
  }

  /* Title row */
  .card-title-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--text);
    line-height: 1.15;
  }

  /* Oneliner */
  .card-oneliner {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.55;
    margin-bottom: 1.125rem;
  }

  .card-live-link {
    margin-left: 0.5em;
    color: var(--accent-light);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 0.8em;
    letter-spacing: 0.04em;
    transition: color var(--transition);
  }

  .card-live-link:hover {
    color: var(--text);
  }

  /* ── Header stats ─────────────────────────────────────── */
  .header-stats {
    display: flex;
    gap: 1.25rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .hstat {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .hstat-value {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--accent-light);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .hstat-label {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(14, 165, 233, 0.35);
  }

  /* ── Tech badges ─────────────────────────────────────── */
  .tech-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .tech-badge {
    font-family: var(--font-mono);
    font-size: 0.575rem;
    font-weight: 500;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.38);
    background: rgba(14, 165, 233, 0.04);
    border: 1px solid rgba(14, 165, 233, 0.14);
    border-radius: 2px;
    padding: 0.25rem 0.5rem;
    transition: color var(--transition), border-color var(--transition);
  }

  .project-card:hover .tech-badge {
    color: rgba(255, 255, 255, 0.5);
    border-color: rgba(14, 165, 233, 0.22);
  }

  .tech-badge--more {
    color: rgba(56, 189, 248, 0.45);
    border-color: rgba(14, 165, 233, 0.18);
  }

  /* ── Toggle button ───────────────────────────────────── */
  .toggle-btn {
    --shimmer-speed: 4s;
    --shimmer-color: rgba(14, 165, 233, 0.5);
    --shimmer-bg: rgba(8, 8, 8, 0.97);

    display: inline-flex;
    align-items: center;
    padding: 0.4rem 0.75rem;
    background: transparent;
    border: 1px solid rgba(14, 165, 233, 0.25);
    border-radius: 2px;
    color: rgba(56, 189, 248, 0.6);
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
    isolation: isolate;
    transition:
      border-color var(--transition),
      color var(--transition);
  }

  .toggle-btn:hover {
    border-color: rgba(14, 165, 233, 0.55);
    color: var(--accent-light);
    background: rgba(14, 165, 233, 0.06);
  }

  .toggle-btn[aria-expanded='true'] {
    border-color: rgba(14, 165, 233, 0.5);
    color: var(--accent-light);
    background: rgba(14, 165, 233, 0.07);
  }

  /* ── Expand panel ────────────────────────────────────── */
  .card-expand {
    height: 0;
    overflow: hidden;
    opacity: 0;
  }

  .card-expand-inner {
    padding: 0 1.5rem 1.5rem;
  }

  /* ── Divider ─────────────────────────────────────────── */
  .expand-divider {
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(14, 165, 233, 0.18), transparent);
    margin-bottom: 1.5rem;
  }

  /* ── Expand sections ─────────────────────────────────── */
  .expand-section {
    margin-bottom: 1.625rem;
  }

  .expand-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.575rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(56, 189, 248, 0.55);
    margin-bottom: 0.875rem;
    overflow: hidden;
    white-space: nowrap;
  }

  /* ── Stats grid (expanded) ───────────────────────────── */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(80px, 1fr));
    gap: 0.625rem;
  }

  .stat-box {
    background: rgba(14, 165, 233, 0.04);
    border: 1px solid rgba(14, 165, 233, 0.1);
    border-radius: 2px;
    padding: 0.875rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    transition: border-color var(--transition), background var(--transition);
  }

  .stat-box:hover {
    background: rgba(14, 165, 233, 0.08);
    border-color: rgba(14, 165, 233, 0.22);
  }

  .stat-value {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent-light);
    letter-spacing: -0.02em;
    line-height: 1.1;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.575rem;
    color: rgba(14, 165, 233, 0.4);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  /* ── Description ─────────────────────────────────────── */
  .expand-description {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.72;
  }

  /* ── Decisions ───────────────────────────────────────── */
  .decisions-list {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .decision-item {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: 0.9rem;
    line-height: 1.62;
    color: var(--text-muted);
  }

  .decision-arrow {
    color: var(--accent-light);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    flex-shrink: 0;
    margin-top: 0.15em;
    opacity: 0.7;
  }

  /* ── Expand footer ───────────────────────────────────── */
  .expand-footer {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .github-btn {
    --shimmer-speed: 3.5s;
    --shimmer-color: rgba(56, 189, 248, 0.6);
    --shimmer-bg: rgba(14, 165, 233, 0.05);

    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--accent-light);
    text-decoration: none;
    padding: 0.5rem 1rem;
    border: 1px solid rgba(14, 165, 233, 0.3);
    border-radius: 2px;
    background: rgba(14, 165, 233, 0.04);
    position: relative;
    overflow: hidden;
    isolation: isolate;
    transition:
      border-color var(--transition),
      color var(--transition),
      box-shadow var(--transition);
  }

  .github-btn:hover {
    border-color: rgba(14, 165, 233, 0.55);
    color: #fff;
    box-shadow: 0 0 16px rgba(14, 165, 233, 0.18);
  }

  .footer-note {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--text-faint);
    letter-spacing: 0.06em;
  }

  /* ── Mobile ──────────────────────────────────────────── */
  @media (max-width: 600px) {
    .card-header {
      padding: 1.25rem 1.25rem 1rem;
    }

    .card-expand-inner {
      padding: 0 1.25rem 1.25rem;
    }

    .card-title {
      font-size: 1.2rem;
    }

    .toggle-btn {
      font-size: 0.55rem;
      padding: 0.35rem 0.6rem;
    }

    .stats-row {
      gap: 0.5rem;
    }

    .stat-value {
      font-size: 1.2rem;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';

  let openCardId: string | null = null;
  const timelines = new Map<string, gsap.core.Timeline>();

  const grid = document.querySelector<HTMLElement>('.projects-grid');
  function setGridAlignment(mode: 'start' | '') {
    grid?.querySelectorAll<HTMLElement>('.grid-item').forEach((item) => {
      item.style.alignSelf = mode;
    });
  }

  function buildTimeline(expandEl: HTMLElement): gsap.core.Timeline {
    return gsap.timeline({ paused: true }).fromTo(
      expandEl,
      { height: 0, opacity: 0 },
      { height: 'auto', opacity: 1, duration: 0.45, ease: 'power2.out' }
    );
  }

  function openCard(cardId: string): void {
    const expandEl  = document.querySelector<HTMLElement>(`[data-expand="${cardId}"]`);
    const toggleBtn = document.querySelector<HTMLButtonElement>(`[data-toggle="${cardId}"]`);
    const cardEl    = document.querySelector<HTMLElement>(`[data-card-id="${cardId}"]`);
    if (!expandEl || !toggleBtn || !cardEl) return;

    if (!timelines.has(cardId)) timelines.set(cardId, buildTimeline(expandEl));
    timelines.get(cardId)!.play();

    toggleBtn.setAttribute('aria-expanded', 'true');
    expandEl.setAttribute('aria-hidden', 'false');
    cardEl.classList.add('is-expanded');

    const textEl = toggleBtn.querySelector<HTMLElement>('.toggle-text');
    if (textEl) textEl.textContent = '[ CLOSE ]';

    openCardId = cardId;
    setGridAlignment('start');
  }

  function closeCard(cardId: string): void {
    const expandEl  = document.querySelector<HTMLElement>(`[data-expand="${cardId}"]`);
    const toggleBtn = document.querySelector<HTMLButtonElement>(`[data-toggle="${cardId}"]`);
    const cardEl    = document.querySelector<HTMLElement>(`[data-card-id="${cardId}"]`);
    if (!expandEl || !toggleBtn || !cardEl) return;

    timelines.get(cardId)?.reverse();

    toggleBtn.setAttribute('aria-expanded', 'false');
    expandEl.setAttribute('aria-hidden', 'true');
    cardEl.classList.remove('is-expanded');

    const textEl = toggleBtn.querySelector<HTMLElement>('.toggle-text');
    if (textEl) textEl.textContent = '[ CASE STUDY ]';

    if (openCardId === cardId) openCardId = null;
    if (openCardId === null) {
      gsap.delayedCall(0.5, () => { if (openCardId === null) setGridAlignment(''); });
    }
  }

  (window as any).closeAllCards = function (): void {
    if (openCardId) closeCard(openCardId);
  };

  function initCard(toggleBtn: HTMLButtonElement): void {
    const cardId = toggleBtn.getAttribute('data-toggle');
    if (!cardId) return;
    toggleBtn.addEventListener('click', () => {
      const isOpen = toggleBtn.getAttribute('aria-expanded') === 'true';
      if (isOpen) {
        closeCard(cardId);
      } else {
        if (openCardId && openCardId !== cardId) closeCard(openCardId);
        openCard(cardId);
      }
    });
  }

  function initAll(): void {
    document.querySelectorAll<HTMLButtonElement>('[data-toggle]').forEach(initCard);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAll);
  } else {
    initAll();
  }
</script>
