---
// Skills.astro
// "Capabilities" skill cards — 2-column grid with shared border pattern.
// Light/dark mode via CSS custom properties from global.css.
---

<section id="skills" class="skills-section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Capabilities</h2>
      <span class="section-count label-mono">[ 004 ]</span>
    </div>

    <div class="skills-grid">

      <!-- ── 001 · RPA & Automation ──────────────────────────── -->
      <div class="skill-card" data-animate="fadeUp">
        <div class="skill-card-top">
          <svg class="skill-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 1-6.23-.693L5 14.5m14.8.8 1.402 1.402c1 1 .03 2.603-1.366 2.397l-2.547-.852a9.001 9.001 0 0 0-5.578 0l-2.547.852c-1.396.206-2.366-1.397-1.366-2.397L5 14.5" />
          </svg>
          <h3 class="skill-category">RPA &amp; Automation</h3>
          <span class="skill-index" aria-hidden="true">001</span>
        </div>

        <p class="skill-headline">Enterprise-grade automation at Navy scale.</p>

        <div class="badge-list">
          <span class="tech-badge">UiPath Studio</span>
          <span class="tech-badge">Orchestrator</span>
          <span class="tech-badge">Document Understanding</span>
          <span class="tech-badge">AI Center</span>
          <span class="tech-badge">Attended &amp; Unattended Bots</span>
          <span class="tech-badge">OCR &amp; ML model training</span>
          <span class="tech-badge">Python automation</span>
          <span class="tech-badge">Selenium</span>
          <span class="tech-badge">asyncio</span>
        </div>
      </div>

      <!-- ── 002 · Backend Engineering ──────────────────────── -->
      <div class="skill-card" data-animate="fadeUp">
        <div class="skill-card-top">
          <svg class="skill-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 0 1-3-3m3 3a3 3 0 1 0 0 6h13.5a3 3 0 1 0 0-6m-16.5-3a3 3 0 0 1 3-3h13.5a3 3 0 0 1 3 3m-19.5 0a4.5 4.5 0 0 1 .9-2.7L5.737 5.1a3.375 3.375 0 0 1 2.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 0 1 .9 2.7m0 0a3 3 0 0 1-3 3m0 3h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Zm-3 6h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Z" />
          </svg>
          <h3 class="skill-category">Backend Engineering</h3>
          <span class="skill-index" aria-hidden="true">002</span>
        </div>

        <p class="skill-headline">APIs that don't fall over.</p>

        <div class="badge-list">
          <span class="tech-badge">Python</span>
          <span class="tech-badge">Django</span>
          <span class="tech-badge">DRF</span>
          <span class="tech-badge">FastAPI</span>
          <span class="tech-badge">REST</span>
          <span class="tech-badge">WebSockets</span>
          <span class="tech-badge">PostgreSQL</span>
          <span class="tech-badge">SQLite</span>
          <span class="tech-badge">Docker</span>
          <span class="tech-badge">GCP</span>
          <span class="tech-badge">Heroku</span>
          <span class="tech-badge">Linux</span>
          <span class="tech-badge">systemd</span>
        </div>
      </div>

      <!-- ── 003 · Frontend & Full-Stack ────────────────────── -->
      <div class="skill-card" data-animate="fadeUp">
        <div class="skill-card-top">
          <svg class="skill-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5 3 12l3.75 4.5m10.5 0 3.75-4.5L17.25 7.5M13.5 3 10.5 21" />
          </svg>
          <h3 class="skill-category">Frontend &amp; Full-Stack</h3>
          <span class="skill-index" aria-hidden="true">003</span>
        </div>

        <p class="skill-headline">I build the whole thing.</p>

        <div class="badge-list">
          <span class="tech-badge">React 19</span>
          <span class="tech-badge">TypeScript</span>
          <span class="tech-badge">JavaScript</span>
          <span class="tech-badge">React Native</span>
          <span class="tech-badge">HTMX</span>
          <span class="tech-badge">Tailwind CSS</span>
          <span class="tech-badge">Astro</span>
        </div>
      </div>

      <!-- ── 004 · Algo Trading & Systems ───────────────────── -->
      <div class="skill-card" data-animate="fadeUp">
        <div class="skill-card-top">
          <svg class="skill-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
          </svg>
          <h3 class="skill-category">Algo Trading &amp; Systems</h3>
          <span class="skill-index" aria-hidden="true">004</span>
        </div>

        <p class="skill-headline">Running in production. With real money.</p>

        <div class="badge-list">
          <span class="tech-badge">Algorithmic trading</span>
          <span class="tech-badge">Kalshi API</span>
          <span class="tech-badge">Coinbase Advanced Trade</span>
          <span class="tech-badge">JSONL logging</span>
          <span class="tech-badge">Telegram bots</span>
          <span class="tech-badge">Circuit breakers</span>
          <span class="tech-badge">Risk management</span>
          <span class="tech-badge">asyncio event loops</span>
        </div>
      </div>

    </div>

    <p class="skills-outro">Currently at Baker Tilly, always shipping something on the side.</p>

  </div>
</section>

<style>
  .skills-section {
    padding-block: var(--section-gap);
  }

  /* ── Grid ─────────────────────────────────────────────────── */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    margin-bottom: 3rem;
    border-top: 1px solid var(--border);
    border-left: 1px solid var(--border);
  }

  /* ── Skill card ───────────────────────────────────────────── */
  .skill-card {
    background: var(--bg-card);
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
    transition: background var(--transition);
    cursor: default;
  }

  .skill-card:hover {
    background: var(--bg-elevated);
  }

  /* ── Card top row ─────────────────────────────────────────── */
  .skill-card-top {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .skill-icon {
    width: 1rem;
    height: 1rem;
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .skill-category {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    line-height: 1.2;
    flex: 1;
  }

  .skill-index {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    color: var(--text-faint);
    flex-shrink: 0;
  }

  /* ── Tagline ──────────────────────────────────────────────── */
  .skill-headline {
    font-size: 0.8125rem;
    color: var(--text-muted);
    font-style: italic;
    line-height: 1.5;
  }

  /* ── Outro ────────────────────────────────────────────────── */
  .skills-outro {
    text-align: center;
    color: var(--text-muted);
    font-size: 0.875rem;
    font-style: italic;
  }

  /* ── Mobile ───────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
