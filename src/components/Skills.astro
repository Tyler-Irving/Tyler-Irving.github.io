---
// Skills.astro
---

<section id="skills" class="skills-section">
  <div class="container">
    <span class="section-label">Capabilities</span>
    <h2 class="section-heading">What I bring.</h2>

    <div class="skills-grid">

      <!-- RPA & Automation -->
      <div class="skill-card" data-animate="fadeUp">
        <h3 class="skill-category">RPA &amp; Automation</h3>
        <p class="skill-headline">Enterprise-grade automation at Navy scale.</p>
        <div class="badge-list">
          <span class="tech-badge">UiPath Studio</span>
          <span class="tech-badge">Orchestrator</span>
          <span class="tech-badge">Document Understanding</span>
          <span class="tech-badge">AI Center</span>
          <span class="tech-badge">Attended &amp; Unattended Bots</span>
          <span class="tech-badge">OCR &amp; ML model training</span>
          <span class="tech-badge">Python automation</span>
          <span class="tech-badge">Selenium</span>
          <span class="tech-badge">asyncio</span>
        </div>
      </div>

      <!-- Backend Engineering -->
      <div class="skill-card" data-animate="fadeUp">
        <h3 class="skill-category">Backend Engineering</h3>
        <p class="skill-headline">APIs that don't fall over.</p>
        <div class="badge-list">
          <span class="tech-badge">Python</span>
          <span class="tech-badge">Django</span>
          <span class="tech-badge">DRF</span>
          <span class="tech-badge">FastAPI</span>
          <span class="tech-badge">REST</span>
          <span class="tech-badge">WebSockets</span>
          <span class="tech-badge">PostgreSQL</span>
          <span class="tech-badge">SQLite</span>
          <span class="tech-badge">Docker</span>
          <span class="tech-badge">GCP</span>
          <span class="tech-badge">Heroku</span>
          <span class="tech-badge">Linux</span>
          <span class="tech-badge">systemd</span>
        </div>
      </div>

      <!-- Frontend & Full-Stack -->
      <div class="skill-card" data-animate="fadeUp">
        <h3 class="skill-category">Frontend &amp; Full-Stack</h3>
        <p class="skill-headline">I build the whole thing.</p>
        <div class="badge-list">
          <span class="tech-badge">React 19</span>
          <span class="tech-badge">TypeScript</span>
          <span class="tech-badge">JavaScript</span>
          <span class="tech-badge">React Native</span>
          <span class="tech-badge">HTMX</span>
          <span class="tech-badge">Tailwind CSS</span>
          <span class="tech-badge">Astro</span>
        </div>
      </div>

      <!-- Algo Trading & Systems -->
      <div class="skill-card" data-animate="fadeUp">
        <h3 class="skill-category">Algo Trading &amp; Systems</h3>
        <p class="skill-headline">Running in production. With real money.</p>
        <div class="badge-list">
          <span class="tech-badge">Algorithmic trading</span>
          <span class="tech-badge">Kalshi API</span>
          <span class="tech-badge">Coinbase Advanced Trade</span>
          <span class="tech-badge">JSONL logging</span>
          <span class="tech-badge">Telegram bots</span>
          <span class="tech-badge">Circuit breakers</span>
          <span class="tech-badge">Risk management</span>
          <span class="tech-badge">asyncio event loops</span>
        </div>
      </div>

    </div>

    <!-- Clearance strip -->
    <div class="clearance-strip" data-animate="fadeUp" aria-label="Security clearance status">
      <span class="clearance-strip-text">
        <span class="clearance-icon" aria-hidden="true">&#x1F510;</span>
        SECRET SECURITY CLEARANCE &middot; ACTIVE &middot; BAKER TILLY
      </span>
    </div>

    <!-- Outro -->
    <p class="skills-outro">Currently at Baker Tilly, always shipping something on the side.</p>

  </div>
</section>

<style>
  /* ── Section chrome ───────────────────────────────────────── */
  .skills-section {
    padding-block: var(--section-gap);
  }

  .section-heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--text);
    margin-bottom: 3rem;
  }

  /* ── Grid ─────────────────────────────────────────────────── */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  /* ── Skill card ───────────────────────────────────────────── */
  .skill-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: border-color var(--transition), box-shadow var(--transition), transform var(--transition);
  }

  .skill-card:hover {
    border-color: var(--border-hover);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .skill-category {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--accent-light);
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .skill-headline {
    font-size: 0.875rem;
    color: var(--text-muted);
    font-style: italic;
    line-height: 1.5;
  }

  /* ── Clearance strip ──────────────────────────────────────── */
  .clearance-strip {
    width: 100%;
    border: 1px solid var(--accent);
    border-radius: var(--radius-md);
    padding: 1rem 1.5rem;
    background: var(--accent-glow);
    text-align: center;
    margin-bottom: 2.5rem;
    box-shadow: 0 0 24px rgba(124, 58, 237, 0.08);
  }

  .clearance-strip-text {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-light);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .clearance-icon {
    font-size: 1rem;
  }

  /* ── Outro line ───────────────────────────────────────────── */
  .skills-outro {
    text-align: center;
    color: var(--text-muted);
    font-size: 0.9rem;
    font-style: italic;
  }

  /* ── Mobile ───────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
